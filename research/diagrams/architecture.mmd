  end

  subgraph runtime["gaxd sidecar"]
    GAXD["gaxd"]
    REG["Command registry"]
    PROJ["Projection layer"]
    ADP["Adapters"]
  end

  LLM --> INV
  LLM --> DOC
  INV --> GAXD
  DOC --> GAXD
  GAXD --> AUTH
  GAXD --> CAP
  GAXD --> POL
  GAXD --> TEN
